# ──────────────────────────────────────────────────────────────────────────
# Cura — Environment variables
# Copy this file to `.env.local` and fill in your secrets. NEVER commit .env.local.
# All keys below are read server-side only (Next.js route handlers). Nothing is
# exposed to the browser.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED — auth + database) ──────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API.
#   - Project URL:        Settings → API → "Project URL"
#   - anon public key:    Settings → API → "Project API keys" → anon/public
#   - service_role key:   Settings → API → "Project API keys" → service_role
# The service_role key is SECRET (server-only) — never expose it to the browser.
# In Supabase → Authentication → URL Configuration, add redirect URLs:
#   <NEXT_PUBLIC_APP_URL>/auth/callback
#   http://localhost:3000/auth/callback
#
# Google login (Supabase Auth — separate from Calendar GOOGLE_* below):
#   1. Supabase → Authentication → Providers → Google → Enable
#   2. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
#      (Web application; Authorized redirect URI = your Supabase callback, e.g.
#       https://<project-ref>.supabase.co/auth/v1/callback)
#   3. Paste Client ID + Client Secret into the Supabase Google provider settings
#   4. Site URL in Supabase: <NEXT_PUBLIC_APP_URL>
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin (dev credentials — TODO: replace before production) ────────────────
# Default login: user "a", code "123456" when unset.
ADMIN_USER=a
ADMIN_CODE=123456
# Secret for signing the admin_session cookie (min. 32 chars in production).
ADMIN_SESSION_SECRET=

# Create a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Shared secret for verifying post-call webhooks (HMAC).
# Generate it when you enable the webhook in the ElevenLabs Agents settings:
# https://elevenlabs.io/app/agents/settings
ELEVENLABS_WEBHOOK_SECRET=

# ── Call forwarding — number pool (Option B, one DID per tenant) ─────────────
# Comma-separated E.164 numbers already imported in ElevenLabs (Twilio/SIP).
# Each new user gets the next free number; must exist in your ElevenLabs workspace.
# Legacy single-number fallback (optional if CURA_NUMBER_POOL is empty):
CURA_NUMBER_POOL=+41 44 505 46 32
CURA_FORWARDING_NUMBER=+41 44 505 46 32

# Optional default voice for auto-provisioned agents (ElevenLabs voice_id).
# If empty, the first German-capable voice in the workspace is used.
DEFAULT_AGENT_VOICE_ID=

# Landing-page demo voices (optional — falls back to DEFAULT_AGENT_VOICE_ID / workspace)
DEMO_VOICE_FEMALE_DE=
DEMO_VOICE_MALE_CH=

# Landing-page outbound demo call (optional env override for ElevenLabs phone_number_id)
# Preferred: Admin → Einstellungen → Live-Demo-Nummer
DEMO_AGENT_ID=
DEMO_AGENT_PHONE_NUMBER_ID=

# ── Enrichment (OPTIONAL — Cura's value-add) ───────────────────────────────
# When set, every saved call gets a second LLM pass that produces a tighter
# German title/summary, a category, an urgency and suggested actions.
# If left empty, Cura falls back to ElevenLabs' own call analysis.
# Any OpenAI-compatible Chat Completions endpoint works.
# Optional fallback — prefer Admin → Einstellungen → KI (Agent & Anrufe)
ENRICHMENT_API_KEY=
ENRICHMENT_BASE_URL=https://api.openai.com/v1
ENRICHMENT_MODEL=gpt-4o-mini

# ── App ────────────────────────────────────────────────────────────────────
# Public base URL of this app (used to show the webhook URL in the UI and to
# build OAuth redirect URIs). In dev with a tunnel, set this to the tunnel URL,
# e.g. https://abc123.trycloudflare.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Calendar integrations (OPTIONAL — for appointment booking) ─────────────
# Google Calendar (OAuth 2.0). Create credentials at
# https://console.cloud.google.com/apis/credentials
#   - Enable the "Google Calendar API"
#   - OAuth client type: Web application
#   - Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (Outlook / Microsoft 365, Microsoft Graph). Register an app at
# https://portal.azure.com → App registrations
#   - Supported account types: any (multitenant + personal)
#   - Redirect URI (Web): <NEXT_PUBLIC_APP_URL>/api/integrations/microsoft/callback
#   - API permissions (delegated): Calendars.ReadWrite, User.Read, offline_access
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Apple Calendar needs NO app registration here — the customer connects in the
# UI with their Apple ID + an app-specific password (appleid.apple.com).

# Shared secret protecting the appointment tool endpoint that the ElevenLabs
# agent calls (/api/agent-tools/appointment). Generate a random string and set
# the same value as the Bearer token in the ElevenLabs server-tool config.
AGENT_TOOL_SECRET=

# ── Billing / Stripe (REQUIRED for token purchases) ────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys (test key in dev).
# Can be set here OR in Admin → Einstellungen → Stripe Secret Key
STRIPE_SECRET_KEY=
# Webhook signing secret — endpoint: <NEXT_PUBLIC_APP_URL>/api/webhooks/stripe
# Events: checkout.session.completed
# Can be set here OR in Admin → Einstellungen → Stripe Webhook Secret
STRIPE_WEBHOOK_SECRET=
# Set to true only in local dev to credit tokens without Stripe (never in production).
# BILLING_TEST_MODE=false
#
# Apple Pay: Stripe Checkout shows Apple Pay automatically when automatic_payment_methods
# is enabled. Register your domain under Stripe Dashboard → Settings → Payment methods
# → Apple Pay → Add domain (production + ngrok URL for local testing).

# Transactional email (token purchase receipts) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Cura <billing@your-domain.com>

# ── Admin finances (OPTIONAL — cost estimates for /admin/finances) ───────────
# Monthly cost per phone number in the pool (Twilio + ElevenLabs DID).
FINANCE_NUMBER_MONTHLY_CHF=1.1
# Estimated ElevenLabs conversational AI cost per call minute.
FINANCE_ELEVENLABS_PER_MINUTE_CHF=0.15
# Optional fixed monthly ElevenLabs platform fee.
FINANCE_ELEVENLABS_PLATFORM_MONTHLY_CHF=0
