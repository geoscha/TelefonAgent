{
  "name": "linker-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 10240 2>/dev/null; NEXT_DIST_DIR=.next-dev next dev",
    "dev:tunnel": "npx --yes cloudflared tunnel --url http://localhost:3000",
    "dev:clean": "rm -rf .next .next-dev && NEXT_DIST_DIR=.next-dev next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "migrate:elevenlabs-flash": "npx tsx scripts/migrate-elevenlabs-flash.ts",
    "migrate:elevenlabs-agent-config": "npx tsx scripts/migrate-elevenlabs-flash.ts",
    "debug:apple-calendar": "node --env-file=.env.local scripts/debug-apple-calendar.mjs",
    "debug:apple-calendar:book": "node --env-file=.env.local scripts/debug-apple-calendar.mjs --book"
  },
  "dependencies": {
    "@elevenlabs/client": "^1.12.0",
    "@elevenlabs/elevenlabs-js": "^2.52.0",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
